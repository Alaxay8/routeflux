#!/bin/sh
set -eu

ROUTEFLUX_VERSION="${ROUTEFLUX_VERSION:-__ROUTEFLUX_VERSION__}"
ROUTEFLUX_SUPPORTED_ARCHES="${ROUTEFLUX_SUPPORTED_ARCHES:-__SUPPORTED_ARCHES__}"
ROUTEFLUX_REPO_OWNER="${ROUTEFLUX_REPO_OWNER:-Alaxay8}"
ROUTEFLUX_REPO_NAME="${ROUTEFLUX_REPO_NAME:-routeflux}"
ROUTEFLUX_RELEASE_BASE_URL="${ROUTEFLUX_RELEASE_BASE_URL:-}"
ROUTEFLUX_INSTALL_ROOT="${ROUTEFLUX_INSTALL_ROOT:-/}"
ROUTEFLUX_ARCH_OVERRIDE="${ROUTEFLUX_ARCH:-}"
ROUTEFLUX_XRAY_BINARY_PATH="${ROUTEFLUX_XRAY_BINARY:-}"
ROUTEFLUX_XRAY_SERVICE_PATH="${ROUTEFLUX_XRAY_SERVICE:-}"
ROUTEFLUX_INSTALL_DEPS="${ROUTEFLUX_INSTALL_DEPS:-1}"
ROUTEFLUX_INSTALL_ZAPRET="${ROUTEFLUX_INSTALL_ZAPRET:-1}"
ROUTEFLUX_ZAPRET_REPO_OWNER="${ROUTEFLUX_ZAPRET_REPO_OWNER:-remittor}"
ROUTEFLUX_ZAPRET_REPO_NAME="${ROUTEFLUX_ZAPRET_REPO_NAME:-zapret-openwrt}"
ROUTEFLUX_ZAPRET_RELEASE_BASE_URL="${ROUTEFLUX_ZAPRET_RELEASE_BASE_URL:-}"
ROUTEFLUX_ZAPRET_VERSION="${ROUTEFLUX_ZAPRET_VERSION:-latest}"
ROUTEFLUX_DRY_RUN=0
ROUTEFLUX_OPKG_UPDATED=0
ROUTEFLUX_INSTALL_MANIFEST_TMP="${ROUTEFLUX_INSTALL_MANIFEST_TMP:-}"

usage() {
	printf '%s\n' "RouteFlux OpenWrt installer"
	printf '%s\n' ""
	printf '%s\n' "Usage: install.sh [--version <version>] [--arch <arch>] [--base-url <url>] [--install-root <path>] [--dry-run] [--without-deps] [--without-zapret] [--zapret-version <version>]"
}

log() {
	printf '%s\n' "$*"
}

warn() {
	printf 'warning: %s\n' "$*" >&2
}

die() {
	printf 'error: %s\n' "$*" >&2
	exit 1
}

command_exists() {
	command -v "$1" >/dev/null 2>&1
}

root_path() {
	path="$1"
	if [ "${ROUTEFLUX_INSTALL_ROOT}" = "/" ]; then
		printf '/%s\n' "${path}"
		return
	fi

	printf '%s/%s\n' "${ROUTEFLUX_INSTALL_ROOT%/}" "${path}"
}

service_path() {
	if [ "$1" = "xray" ] && [ -n "${ROUTEFLUX_XRAY_SERVICE_PATH}" ]; then
		printf '%s\n' "${ROUTEFLUX_XRAY_SERVICE_PATH}"
		return
	fi

	root_path "etc/init.d/$1"
}

xray_binary_path() {
	if [ -n "${ROUTEFLUX_XRAY_BINARY_PATH}" ]; then
		printf '%s\n' "${ROUTEFLUX_XRAY_BINARY_PATH}"
		return
	fi

	root_path "usr/bin/xray"
}

routeflux_cron_helper_path() {
	root_path "usr/libexec/routeflux-cron"
}

install_manifest_path() {
	root_path "etc/routeflux/install-manifest.txt"
}

xray_config_path() {
	root_path "etc/xray/config.json"
}

record_manifest_entry() {
	kind="$1"
	value="$2"

	[ -n "${ROUTEFLUX_INSTALL_MANIFEST_TMP}" ] || return 0
	[ -n "${value}" ] || return 0

	mkdir -p "$(dirname "${ROUTEFLUX_INSTALL_MANIFEST_TMP}")"
	if [ -f "${ROUTEFLUX_INSTALL_MANIFEST_TMP}" ] && grep -Fqx "${kind}=${value}" "${ROUTEFLUX_INSTALL_MANIFEST_TMP}" 2>/dev/null; then
		return 0
	fi

	printf '%s=%s\n' "${kind}" "${value}" >> "${ROUTEFLUX_INSTALL_MANIFEST_TMP}"
}

record_installed_pkg() {
	record_manifest_entry "pkg" "$1"
}

record_restore_pkg() {
	record_manifest_entry "restore" "$1"
}

record_installed_ipk_packages() {
	for ipk in "$@"; do
		base="$(basename "${ipk}" .ipk)"
		pkg="${base%%_*}"
		[ -n "${pkg}" ] || continue
		record_installed_pkg "${pkg}"
	done
}

persist_install_manifest() {
	destination="$(install_manifest_path)"

	if [ -z "${ROUTEFLUX_INSTALL_MANIFEST_TMP}" ] || [ ! -f "${ROUTEFLUX_INSTALL_MANIFEST_TMP}" ]; then
		remove_path="${destination}"
		if [ -f "${remove_path}" ]; then
			rm -f "${remove_path}"
		fi
		return 0
	fi

	mkdir -p "$(dirname "${destination}")"
	cp "${ROUTEFLUX_INSTALL_MANIFEST_TMP}" "${destination}"
	chmod 0600 "${destination}" >/dev/null 2>&1 || true
}

chmod_if_exists() {
	path="$1"
	mode="$2"

	[ -e "${path}" ] || return 0
	chmod "${mode}" "${path}" >/dev/null 2>&1 || return 1
}

harden_secret_storage() {
	routeflux_root="$(root_path "etc/routeflux")"
	if [ -d "${routeflux_root}" ]; then
		chmod 0700 "${routeflux_root}" >/dev/null 2>&1 || true
		for name in subscriptions.json settings.json state.json .routeflux.lock speedtest.lock; do
			chmod_if_exists "${routeflux_root}/${name}" 0600 || true
		done
		find "${routeflux_root}" -maxdepth 1 -type f -name '*.corrupt-*' -exec chmod 0600 {} \; >/dev/null 2>&1 || true
	fi

	xray_config="$(xray_config_path)"
	chmod_if_exists "${xray_config}" 0600 || true
	chmod_if_exists "${xray_config}.last-known-good" 0600 || true
}

require_root_if_needed() {
	if [ "${ROUTEFLUX_INSTALL_ROOT}" = "/" ] && [ "$(id -u)" -ne 0 ]; then
		die "run this installer as root on the router, or use --install-root for a staging directory"
	fi
}

is_supported_arch() {
	arch="$1"
	for supported in ${ROUTEFLUX_SUPPORTED_ARCHES}; do
		if [ "${arch}" = "${supported}" ]; then
			return 0
		fi
	done
	return 1
}

list_opkg_architectures() {
	if ! command_exists opkg; then
		return 0
	fi

	opkg print-architecture 2>/dev/null | while read -r kind arch _priority; do
		if [ "${kind}" != "arch" ]; then
			continue
		fi
		if [ "${arch}" = "all" ] || [ "${arch}" = "noarch" ]; then
			continue
		fi
		printf '%s\n' "${arch}"
	done
}

detect_uname_arch() {
	if ! command_exists uname; then
		return 0
	fi

	machine="$(uname -m 2>/dev/null || true)"
	case "${machine}" in
		x86_64|amd64)
			printf 'x86_64\n'
			;;
	esac
}

resolve_arch() {
	if [ -n "${ROUTEFLUX_ARCH_OVERRIDE}" ]; then
		printf '%s\n' "${ROUTEFLUX_ARCH_OVERRIDE}"
		return 0
	fi

	opkg_arches="$(list_opkg_architectures)"
	if [ -n "${opkg_arches}" ]; then
		for candidate in ${opkg_arches}; do
			if is_supported_arch "${candidate}"; then
				printf '%s\n' "${candidate}"
				return 0
			fi
		done
		return 1
	fi

	for candidate in $(detect_uname_arch); do
		if is_supported_arch "${candidate}"; then
			printf '%s\n' "${candidate}"
			return 0
		fi
	done

	return 1
}

download_file() {
	url="$1"
	destination="$2"

	if command_exists wget; then
		wget -O "${destination}" "${url}"
		return 0
	fi

	if command_exists curl; then
		curl -fsSL -o "${destination}" "${url}"
		return 0
	fi

	die "wget or curl is required to download release assets"
}

run_service_if_present() {
	name="$1"
	action="$2"
	script="$(service_path "${name}")"

	if [ ! -x "${script}" ]; then
		return 0
	fi

	"${script}" "${action}" >/dev/null 2>&1 || return 1
}

xray_is_ready() {
	[ -x "$(xray_binary_path)" ] && [ -x "$(service_path xray)" ]
}

zapret_is_ready() {
	[ -x "$(service_path zapret)" ]
}

stabilize_zapret_service() {
	if ! zapret_is_ready; then
		return 0
	fi

	if run_service_if_present zapret stop; then
		log "Stopped Zapret service so RouteFlux can manage it"
	fi
	if run_service_if_present zapret disable; then
		log "Disabled Zapret autostart so RouteFlux can manage it"
	fi
}

download_stdout() {
	url="$1"

	if command_exists wget; then
		wget -qO- "${url}"
		return 0
	fi

	if command_exists curl; then
		curl -fsSL "${url}"
		return 0
	fi

	die "wget or curl is required to download release assets"
}

opkg_available() {
	command_exists opkg
}

opkg_update_once() {
	opkg_available || return 0
	if [ "${ROUTEFLUX_OPKG_UPDATED}" = "1" ]; then
		return 0
	fi

	log "Updating opkg package lists"
	opkg update
	ROUTEFLUX_OPKG_UPDATED=1
}

opkg_is_installed() {
	pkg="$1"
	opkg_available || return 1
	opkg list-installed "${pkg}" 2>/dev/null | grep -Fq "${pkg} -"
}

ensure_opkg_package() {
	pkg="$1"
	reason="$2"

	if ! opkg_available; then
		warn "opkg is unavailable, cannot install ${pkg} (${reason})"
		return 0
	fi

	if opkg_is_installed "${pkg}"; then
		log "Detected ${pkg}"
		return 0
	fi

	opkg_update_once
	log "Installing ${pkg} (${reason})"
	opkg install "${pkg}"
	record_installed_pkg "${pkg}"
}

ensure_download_client() {
	if command_exists wget || command_exists curl; then
		log "Detected existing download client"
		return 0
	fi

	if ! opkg_available; then
		die "wget or curl is required to download release assets"
	fi

	ensure_opkg_package curl "required to download release assets"
	if command_exists wget || command_exists curl; then
		return 0
	fi

	ensure_opkg_package wget-ssl "required to download release assets"
	if command_exists wget || command_exists curl; then
		return 0
	fi

	die "wget or curl is required to download release assets"
}

ensure_dnsmasq_full() {
	if ! opkg_available; then
		warn "opkg is unavailable, cannot ensure dnsmasq-full"
		return 0
	fi

	if opkg_is_installed dnsmasq-full; then
		log "Detected dnsmasq-full"
		return 0
	fi

	had_dnsmasq=0
	if opkg_is_installed dnsmasq; then
		had_dnsmasq=1
	fi

	opkg_update_once
	log "Installing dnsmasq-full (required for RouteFlux domain selectors and nftset integration)"
	if opkg install dnsmasq-full; then
		record_installed_pkg dnsmasq-full
		if [ "${had_dnsmasq}" = "1" ]; then
			record_restore_pkg dnsmasq
		fi
		return 0
	fi

	if [ "${had_dnsmasq}" = "1" ]; then
		warn "Replacing dnsmasq with dnsmasq-full"
		record_restore_pkg dnsmasq
		opkg remove dnsmasq || true
		opkg install dnsmasq-full
		record_installed_pkg dnsmasq-full
		return 0
	fi

	die "failed to install dnsmasq-full"
}

ensure_openwrt_dependencies() {
	if [ "${ROUTEFLUX_INSTALL_DEPS}" != "1" ]; then
		log "Skipping OpenWrt dependency installation"
		return 0
	fi

	if ! opkg_available; then
		warn "opkg not found, skipping OpenWrt dependency installation"
		return 0
	fi

	ensure_opkg_package ca-bundle "TLS certificate store for HTTPS downloads"
	ensure_download_client
	ensure_opkg_package nftables "required for RouteFlux transparent routing"
	ensure_opkg_package kmod-nft-tproxy "required for UDP transparent proxy routing"
	ensure_dnsmasq_full
}

resolve_zapret_version() {
	if [ "${ROUTEFLUX_ZAPRET_VERSION}" != "latest" ]; then
		case "${ROUTEFLUX_ZAPRET_VERSION}" in
			v*)
				printf '%s\n' "${ROUTEFLUX_ZAPRET_VERSION}"
				;;
			*)
				printf 'v%s\n' "${ROUTEFLUX_ZAPRET_VERSION}"
				;;
		esac
		return 0
	fi

	api_url="https://api.github.com/repos/${ROUTEFLUX_ZAPRET_REPO_OWNER}/${ROUTEFLUX_ZAPRET_REPO_NAME}/releases/latest"
	tag="$(download_stdout "${api_url}" | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
	[ -n "${tag}" ] || die "failed to resolve the latest zapret-openwrt release tag"
	printf '%s\n' "${tag}"
}

install_zapret_bundle() {
	resolved_arch="$1"
	tmp_dir="$2"

	if [ "${ROUTEFLUX_INSTALL_ZAPRET}" != "1" ]; then
		log "Skipping Zapret installation"
		return 0
	fi

	if zapret_is_ready; then
		log "Detected existing Zapret runtime"
		stabilize_zapret_service
		return 0
	fi

	if ! opkg_available; then
		warn "opkg not found, skipping Zapret installation"
		return 0
	fi

	if ! command_exists unzip; then
		ensure_opkg_package unzip "required to unpack the zapret-openwrt bundle"
	fi
	command_exists unzip || die "unzip is required to unpack the zapret-openwrt bundle"

	zapret_version="$(resolve_zapret_version)"
	if [ -n "${ROUTEFLUX_ZAPRET_RELEASE_BASE_URL}" ]; then
		zapret_release_base_url="${ROUTEFLUX_ZAPRET_RELEASE_BASE_URL}"
	else
		zapret_release_base_url="https://github.com/${ROUTEFLUX_ZAPRET_REPO_OWNER}/${ROUTEFLUX_ZAPRET_REPO_NAME}/releases/download/${zapret_version}"
	fi

	zapret_asset_name="zapret_${zapret_version}_${resolved_arch}.zip"
	zapret_asset_url="${zapret_release_base_url}/${zapret_asset_name}"
	zapret_asset_path="${tmp_dir}/${zapret_asset_name}"
	zapret_extract_dir="${tmp_dir}/zapret-bundle"

	log "Zapret runtime not found, installing bundled Zapret"
	log "Zapret asset: ${zapret_asset_url}"
	download_file "${zapret_asset_url}" "${zapret_asset_path}"

	mkdir -p "${zapret_extract_dir}"
	unzip -oq "${zapret_asset_path}" -d "${zapret_extract_dir}"

	zapret_ipks="$(find "${zapret_extract_dir}" -type f -name 'zapret*.ipk' | sort)"
	[ -n "${zapret_ipks}" ] || die "downloaded zapret bundle did not contain any zapret ipk packages"

	opkg install ${zapret_ipks}
	record_installed_ipk_packages ${zapret_ipks}

	if ! zapret_is_ready; then
		die "zapret packages were installed but /etc/init.d/zapret is still missing"
	fi

	stabilize_zapret_service

	log "Bundled Zapret installed"
}

ensure_xray_log_retention() {
	helper="$(routeflux_cron_helper_path)"
	[ -x "${helper}" ] || return 0
	ROUTEFLUX_INSTALL_ROOT="${ROUTEFLUX_INSTALL_ROOT}" "${helper}" ensure-xray-log-retention
}

while [ "$#" -gt 0 ]; do
	case "$1" in
		--version)
			[ "$#" -ge 2 ] || die "missing value for --version"
			ROUTEFLUX_VERSION="${2#v}"
			shift 2
			;;
		--arch)
			[ "$#" -ge 2 ] || die "missing value for --arch"
			ROUTEFLUX_ARCH_OVERRIDE="$2"
			shift 2
			;;
		--base-url)
			[ "$#" -ge 2 ] || die "missing value for --base-url"
			ROUTEFLUX_RELEASE_BASE_URL="$2"
			shift 2
			;;
		--install-root)
			[ "$#" -ge 2 ] || die "missing value for --install-root"
			ROUTEFLUX_INSTALL_ROOT="$2"
			shift 2
			;;
		--dry-run)
			ROUTEFLUX_DRY_RUN=1
			shift
			;;
		--without-deps)
			ROUTEFLUX_INSTALL_DEPS=0
			shift
			;;
		--without-zapret)
			ROUTEFLUX_INSTALL_ZAPRET=0
			shift
			;;
		--zapret-version)
			[ "$#" -ge 2 ] || die "missing value for --zapret-version"
			ROUTEFLUX_ZAPRET_VERSION="$2"
			shift 2
			;;
		-h|--help)
			usage
			exit 0
			;;
		*)
			die "unknown argument: $1"
			;;
	esac
done

require_root_if_needed

if [ -z "${ROUTEFLUX_RELEASE_BASE_URL}" ]; then
	ROUTEFLUX_RELEASE_BASE_URL="https://github.com/${ROUTEFLUX_REPO_OWNER}/${ROUTEFLUX_REPO_NAME}/releases/download/v${ROUTEFLUX_VERSION}"
fi

resolved_arch="$(resolve_arch || true)"
if [ -z "${resolved_arch}" ]; then
	detected=""
	if command_exists opkg; then
		detected="$(list_opkg_architectures | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
	fi
	if [ -z "${detected}" ]; then
		detected="$(detect_uname_arch | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
	fi
	[ -n "${detected}" ] || detected="unknown"
	die "unsupported architecture: ${detected}. Supported release arches: ${ROUTEFLUX_SUPPORTED_ARCHES}"
fi

if ! is_supported_arch "${resolved_arch}"; then
	die "unsupported architecture: ${resolved_arch}. Supported release arches: ${ROUTEFLUX_SUPPORTED_ARCHES}"
fi

asset_name="routeflux_${ROUTEFLUX_VERSION}_${resolved_arch}.tar.gz"
asset_url="${ROUTEFLUX_RELEASE_BASE_URL}/${asset_name}"
xray_asset_name="xray_${ROUTEFLUX_VERSION}_${resolved_arch}.tar.gz"
xray_asset_url="${ROUTEFLUX_RELEASE_BASE_URL}/${xray_asset_name}"

log "RouteFlux version: ${ROUTEFLUX_VERSION}"
log "RouteFlux arch: ${resolved_arch}"
log "RouteFlux asset: ${asset_url}"

if [ "${ROUTEFLUX_DRY_RUN}" = "1" ]; then
	exit 0
fi

command_exists tar || die "tar is required to install release assets"

tmp_dir="${TMPDIR:-/tmp}/routeflux-install.$$"
asset_path="${tmp_dir}/${asset_name}"
xray_asset_path="${tmp_dir}/${xray_asset_name}"
mkdir -p "${tmp_dir}"
trap 'rm -rf "${tmp_dir}"' EXIT HUP INT TERM
ROUTEFLUX_INSTALL_MANIFEST_TMP="${tmp_dir}/install-manifest.txt"
if [ -f "$(install_manifest_path)" ]; then
	cp "$(install_manifest_path)" "${ROUTEFLUX_INSTALL_MANIFEST_TMP}"
fi

ensure_openwrt_dependencies

if xray_is_ready; then
	log "Detected existing Xray runtime"
else
	log "Xray runtime not found, installing bundled Xray"
	log "Xray asset: ${xray_asset_url}"
	download_file "${xray_asset_url}" "${xray_asset_path}"
	mkdir -p "${ROUTEFLUX_INSTALL_ROOT}"
	tar -xzf "${xray_asset_path}" -C "${ROUTEFLUX_INSTALL_ROOT}"
	xray_service="$(service_path xray)"
	if [ -f "${xray_service}" ]; then
		chmod 0755 "${xray_service}" || true
	fi
	log "Bundled Xray installed"
fi

install_zapret_bundle "${resolved_arch}" "${tmp_dir}"

log "Downloading RouteFlux release asset"
download_file "${asset_url}" "${asset_path}"

log "Extracting files into ${ROUTEFLUX_INSTALL_ROOT}"
mkdir -p "${ROUTEFLUX_INSTALL_ROOT}"
tar -xzf "${asset_path}" -C "${ROUTEFLUX_INSTALL_ROOT}"

routeflux_service="$(service_path routeflux)"
if [ -f "${routeflux_service}" ]; then
	chmod 0755 "${routeflux_service}" || true
fi

harden_secret_storage
ensure_xray_log_retention
persist_install_manifest

rm -f "$(root_path "tmp/luci-indexcache")"
rm -rf "$(root_path "tmp/luci-modulecache")"
run_service_if_present rpcd reload || true
run_service_if_present uhttpd reload || true
run_service_if_present routeflux enable || true
run_service_if_present routeflux restart || run_service_if_present routeflux start || true

log "RouteFlux installed successfully"
log "Open LuCI: Services -> RouteFlux"
log "CLI example: routeflux add https://provider.example/subscription"
