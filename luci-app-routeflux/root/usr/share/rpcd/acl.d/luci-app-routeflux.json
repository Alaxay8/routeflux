{
	"luci-app-routeflux": {
		"description": "Grant access to RouteFlux status and control",
		"read": {
			"file": {
				"/usr/bin/routeflux --json status": [ "exec" ],
				"/usr/bin/routeflux --json list subscriptions": [ "exec" ],
				"/usr/bin/routeflux --json dns get": [ "exec" ],
				"/usr/bin/routeflux --json firewall get": [ "exec" ],
				"/usr/bin/routeflux --json services list": [ "exec" ]
			}
		},
		"write": {
			"file": {
				"/usr/bin/routeflux *": [ "exec" ],
				"/usr/libexec/routeflux-self-update": [ "exec" ]
			}
		}
	}
}
