{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": {
        "udp": true
      }
    },
    {
      "tag": "http-in",
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http",
      "settings": {}
    },
    {
      "tag": "transparent-in",
      "listen": "0.0.0.0",
      "port": 12345,
      "protocol": "dokodemo-door",
      "settings": {
        "followRedirect": true,
        "network": "tcp"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      },
      "streamSettings": {
        "sockopt": {
          "tproxy": "redirect"
        }
      }
    },
    {
      "tag": "transparent-udp-in",
      "listen": "0.0.0.0",
      "port": 12345,
      "protocol": "dokodemo-door",
      "settings": {
        "followRedirect": true,
        "network": "udp"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      },
      "streamSettings": {
        "sockopt": {
          "tproxy": "tproxy"
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "selected",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "node1.example.com",
            "port": 443,
            "users": [
              {
                "id": "11111111-1111-1111-1111-111111111111",
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "chrome",
          "publicKey": "public-key-1",
          "serverName": "edge.example.com",
          "shortId": "ab12cd34"
        },
        "wsSettings": {
          "headers": {
            "Host": "cdn.example.com"
          },
          "path": "/proxy"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "outboundTag": "selected",
        "inboundTag": [
          "transparent-in"
        ],
        "network": "tcp"
      },
      {
        "type": "field",
        "outboundTag": "selected",
        "inboundTag": [
          "transparent-udp-in"
        ],
        "network": "udp"
      },
      {
        "type": "field",
        "outboundTag": "selected",
        "inboundTag": [
          "socks-in",
          "http-in"
        ],
        "network": "tcp,udp"
      }
    ]
  }
}
