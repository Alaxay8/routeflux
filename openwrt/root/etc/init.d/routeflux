#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

SERVICE_NAME="routeflux"
ROUTEFLUX_BIN="/usr/bin/routeflux"

start_service() {
	local root tick

	root="${ROUTEFLUX_ROOT:-/etc/routeflux}"
	tick="${ROUTEFLUX_SCHEDULER_TICK:-1m}"

	[ -x "${ROUTEFLUX_BIN}" ] || return 1

	procd_open_instance
	procd_set_param command "${ROUTEFLUX_BIN}" --root "${root}" daemon --tick "${tick}"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
